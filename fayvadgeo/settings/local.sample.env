# Django project configuration, if environ vars are missing
#
#   Copy to local.env for development settings.
#   local.env is gitignored — store credentials only on your machine.
#
# Note: No spaces around '=' sign and no quotes for righthand values.

DEBUG=True
# syntax: DATABASE_URL=postgres://username:password@127.0.0.1:5432/database
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/fayvad_survey
# Command to create a new secret key:
# $ python -c 'import secrets; print(secrets.token_urlsafe(50))'
SECRET_KEY=change-me-to-a-random-secret-key
# Optional — enables Google Maps basemap in the map viewer
GOOGLE_MAPS_API_KEY=
