# Copy to .env and adjust. .env is gitignored.
#
# Database runs on the HOST machine (not in Docker).
# @ in passwords must be URL-encoded as %40 in DATABASE_URL.

DEBUG=False
WEB_PORT=8015
APP_PORT=8015
DJANGO_SETTINGS_MODULE=fayvadgeo.settings.docker

SECRET_KEY=change-me-to-a-random-secret-key
DATABASE_URL=postgres://fayvad:your-password@host.docker.internal:5432/fayvad_survey

ALLOWED_HOSTS=localhost,127.0.0.1,survey.fayvad.com
CSRF_TRUSTED_ORIGINS=https://survey.fayvad.com,http://localhost:8015

GOOGLE_MAPS_API_KEY=
